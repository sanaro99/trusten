# Server
NODE_ENV=development
LOG_LEVEL=info
PORT=9200

# ─── LLM Provider ──────────────────────────────────────────────────────────────
# Set TRUSTEN_LLM_PROVIDER to pin a provider, or leave unset for auto-detection.
# Auto-detect order: nvidia-nim → gemini → deepseek → openrouter → ollama
#
# TRUSTEN_LLM_PROVIDER=nvidia-nim   # nvidia-nim | gemini | deepseek | openrouter | ollama
# TRUSTEN_LLM_TIMEOUT_MS=8000

# Nvidia NIM (primary default when key is present)
# NVIDIA_NIM_API_KEY=nvapi-...
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct

# Google Gemini
# TRUSTEN_GEMINI_API_KEY=AIza...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# OpenRouter (routes to any model; default: deepseek/deepseek-chat)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=deepseek/deepseek-chat

# Ollama (local, no key needed — final fallback)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# ─── Telemetry (optional) ──────────────────────────────────────────────────────
# POSTHOG_API_KEY=
# SENTRY_DSN=
